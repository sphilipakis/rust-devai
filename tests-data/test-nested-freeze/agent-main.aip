

# Before All

```lua

-- Load 60 (max) files
local all_files = aip.file.list({
	"src/**/*.{rs,js,txt,cpp,hpp,qml}",
})
local max = 60
local files = {}
for i = 1, math.min(#all_files, max) do
    files[i] = all_files[i]
end

print("agent-main files:", #files)

return aip.flow.before_all_response({
	inputs = files,
	options = {
		input_concurrency = 22
	}
})
```

